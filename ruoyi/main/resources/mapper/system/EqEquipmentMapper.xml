<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.EqEquipmentMapper">
    
    <resultMap type="EqEquipment" id="EqEquipmentResult">
        <result property="equipmentId"    column="equipment_id"    />
        <result property="equipmentName"    column="equipment_name"    />
        <result property="categoryId"    column="category_id"    />
        <result property="image"    column="image"    />
        <result property="totalStock"    column="total_stock"    />
        <result property="remainStock"    column="remain_stock"    />
        <result property="status"    column="status"    />
        <result property="location"    column="location"    />
        <result property="description"    column="description"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectEqEquipmentVo">
        select equipment_id, equipment_name, category_id, image, total_stock, remain_stock, status, location, description, del_flag, create_by, create_time, update_by, update_time, remark from eq_equipment
    </sql>

    <select id="selectEqEquipmentList" parameterType="EqEquipment" resultMap="EqEquipmentResult">
        <include refid="selectEqEquipmentVo"/>
        <where>  
            <if test="equipmentName != null  and equipmentName != ''"> and equipment_name like concat('%', #{equipmentName}, '%')</if>
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectEqEquipmentByEquipmentId" parameterType="Long" resultMap="EqEquipmentResult">
        <include refid="selectEqEquipmentVo"/>
        where equipment_id = #{equipmentId}
    </select>

    <insert id="insertEqEquipment" parameterType="EqEquipment" useGeneratedKeys="true" keyProperty="equipmentId">
        insert into eq_equipment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="equipmentName != null and equipmentName != ''">equipment_name,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="image != null">image,</if>
            <if test="totalStock != null">total_stock,</if>
            <if test="remainStock != null">remain_stock,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="location != null">location,</if>
            <if test="description != null">description,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="equipmentName != null and equipmentName != ''">#{equipmentName},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="image != null">#{image},</if>
            <if test="totalStock != null">#{totalStock},</if>
            <if test="remainStock != null">#{remainStock},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="location != null">#{location},</if>
            <if test="description != null">#{description},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateEqEquipment" parameterType="EqEquipment">
        update eq_equipment
        <trim prefix="SET" suffixOverrides=",">
            <if test="equipmentName != null and equipmentName != ''">equipment_name = #{equipmentName},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="image != null">image = #{image},</if>
            <if test="totalStock != null">total_stock = #{totalStock},</if>
            <if test="remainStock != null">remain_stock = #{remainStock},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="location != null">location = #{location},</if>
            <if test="description != null">description = #{description},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where equipment_id = #{equipmentId}
    </update>

    <delete id="deleteEqEquipmentByEquipmentId" parameterType="Long">
        delete from eq_equipment where equipment_id = #{equipmentId}
    </delete>

    <delete id="deleteEqEquipmentByEquipmentIds" parameterType="String">
        delete from eq_equipment where equipment_id in 
        <foreach item="equipmentId" collection="array" open="(" separator="," close=")">
            #{equipmentId}
        </foreach>
    </delete>
</mapper>