<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.equipment.info.mapper.EqEquipmentMapper">

    <!-- 修复：equipmentId 映射到正确的 equipment_id 字段 -->
    <resultMap type="EqEquipment" id="EqEquipmentResult">
        <result property="equipmentId"    column="equipment_id"    />
        <result property="equipmentName"  column="equipment_name"  />
        <result property="categoryId"     column="category_id"     />
        <result property="categoryName"   column="category_name"   />
        <result property="image"          column="image"           />
        <result property="totalStock"     column="total_stock"     />
        <result property="remainStock"    column="remain_stock"    />
        <result property="status"         column="status"          />
        <result property="location"       column="location"        />
        <result property="description"    column="description"     />
        <result property="delFlag"        column="del_flag"        />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
    </resultMap>

    <sql id="selectEqEquipmentVo">
        select
        e.equipment_id, e.equipment_name, e.category_id,
        IFNULL(c.category_name, '') as category_name,
        e.image, e.total_stock, e.remain_stock, e.status,
        e.location, e.description, e.del_flag, e.create_by,
        e.create_time, e.update_by, e.update_time, e.remark
        from eq_equipment e
        left join eq_category c on e.category_id = c.category_id
    </sql>

    <select id="selectEqEquipmentList" parameterType="EqEquipment" resultMap="EqEquipmentResult">
        <include refid="selectEqEquipmentVo"/>
        <where>
            e.del_flag = '0'
            <if test="equipmentName != null and equipmentName != ''">
                and e.equipment_name like concat('%', #{equipmentName}, '%')
            </if>
            <if test="categoryIds != null and categoryIds.size() > 0">
                and e.category_id in
                <foreach item="cid" collection="categoryIds" open="(" separator="," close=")">
                    #{cid}
                </foreach>
            </if>
            <if test="categoryIds == null and categoryId != null">
                and e.category_id = #{categoryId}
            </if>
            <if test="status != null and status != ''">
                and e.status = #{status}
            </if>
        </where>
    </select>

    <select id="selectEqEquipmentByEquipmentId" parameterType="Long" resultMap="EqEquipmentResult">
        <include refid="selectEqEquipmentVo"/>
        where e.equipment_id = #{equipmentId}
    </select>

    <!-- 修复：insert 时强制非空字段（匹配表结构的 NOT NULL） -->
    <insert id="insertEqEquipment" parameterType="EqEquipment" useGeneratedKeys="true" keyProperty="equipmentId">
        insert into eq_equipment
        (
            equipment_name, category_id, image, total_stock, remain_stock,
            status, location, description, del_flag, create_by,
            create_time, update_by, update_time, remark
        )
        values
            (
                #{equipmentName}, #{categoryId}, #{image}, #{totalStock}, #{remainStock},
                #{status}, #{location}, #{description}, #{delFlag}, #{createBy},
                #{createTime}, #{updateBy}, #{updateTime}, #{remark}
            )
    </insert>

    <update id="updateEqEquipment" parameterType="EqEquipment">
        update eq_equipment
        <trim prefix="SET" suffixOverrides=",">
            <if test="equipmentName != null and equipmentName != ''">equipment_name = #{equipmentName},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="image != null">image = #{image},</if>
            <if test="totalStock != null">total_stock = #{totalStock},</if>
            <if test="remainStock != null">remain_stock = #{remainStock},</if>
            <if test="status != null">status = #{status},</if>
            <if test="location != null">location = #{location},</if>
            <if test="description != null">description = #{description},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where equipment_id = #{equipmentId}
    </update>

    <!-- 修复：改为逻辑删除，而非物理删除 -->
    <update id="deleteEqEquipmentByEquipmentId" parameterType="Long">
        update eq_equipment
        set del_flag = '2'
        where equipment_id = #{equipmentId}
    </update>

    <update id="deleteEqEquipmentByEquipmentIds" parameterType="String">
        update eq_equipment
        set del_flag = '2'
        where equipment_id in
        <foreach item="equipmentId" collection="array" open="(" separator="," close=")">
            #{equipmentId}
        </foreach>
    </update>
</mapper>